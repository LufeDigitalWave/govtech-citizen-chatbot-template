# GovTech Citizen Chatbot — environment variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ─────────────────────────────────────────────────────────────────────────────
# Chatwoot
# ─────────────────────────────────────────────────────────────────────────────
# Base URL of your Chatwoot instance (no trailing slash)
CHATWOOT_URL=https://chatwoot.yourprefeitura.gov.br

# User access token (Settings > Access Token in Chatwoot)
CHATWOOT_API_TOKEN=your_chatwoot_token_here

# Account ID (visible in the URL: /app/accounts/{ID}/...)
CHATWOOT_ACCOUNT_ID=1

# ─────────────────────────────────────────────────────────────────────────────
# WhatsApp — Evolution API
# ─────────────────────────────────────────────────────────────────────────────
# Base URL of your Evolution API instance
EVOLUTION_URL=https://evolution.yourprefeitura.gov.br

# Global API key (set during Evolution API setup)
EVOLUTION_API_KEY=your_evolution_api_key_here

# Instance name you created in Evolution (e.g., "prefeitura-bot")
EVOLUTION_INSTANCE=prefeitura-bot

# ─────────────────────────────────────────────────────────────────────────────
# OpenAI
# ─────────────────────────────────────────────────────────────────────────────
# Required when AGENT_TYPE=faq
OPENAI_API_KEY=sk-proj-...

# Model to use. gpt-4.1 is recommended for production quality.
OPENAI_MODEL=gpt-4.1

# ─────────────────────────────────────────────────────────────────────────────
# Infrastructure
# ─────────────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
DATABASE_URL=postgresql+asyncpg://chatbot:chatbot@localhost:5432/chatbot

# Postgres password (used by docker-compose.yml)
POSTGRES_PASSWORD=changeme

# ─────────────────────────────────────────────────────────────────────────────
# Bot configuration
# ─────────────────────────────────────────────────────────────────────────────
# Which agent to load: "faq" (production) or "echo" (testing/demo)
AGENT_TYPE=faq

# Municipality name shown in the agent's system prompt
AGENT_CITY=São Paulo

# Path to FAQ YAML file (relative to working directory inside the container)
FAQ_PATH=agents/faq/faq_data.yaml

# WhatsApp number to receive error alerts (E.164 without +, e.g., 5511999999999)
# Leave empty to disable admin notifications
ADMIN_PHONE=

# ─────────────────────────────────────────────────────────────────────────────
# Security
# ─────────────────────────────────────────────────────────────────────────────
# HMAC-SHA256 secret for Chatwoot webhook signature verification.
# Set this in production. Leave empty only for internal/private deployments.
WEBHOOK_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# Observability
# ─────────────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# Set to true in production to emit JSON logs for log aggregators (Loki, Datadog)
JSON_LOGS=false
